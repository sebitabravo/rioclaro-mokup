# RíoClaro - Environment Configuration
# Copy this file to .env and configure your values

# ========== APPLICATION SETTINGS ==========
NODE_ENV=development
VITE_DATA_SOURCE=API

# ========== DATABASE SETTINGS ==========
MYSQL_ROOT_PASSWORD=rioclaro_root
MYSQL_DATABASE=rioclaro
MYSQL_USER=rioclaro_user
MYSQL_PASSWORD=rioclaro_pass
MYSQL_PORT=3306

# ========== BACKEND SETTINGS ==========
DJANGO_ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
DB_ENGINE=django.db.backends.mysql

# ========== REDIS SETTINGS ==========
REDIS_PORT=6379

# ========== FRONTEND SETTINGS ==========
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173
BACKEND_PORT=8000

# ========== CORS SETTINGS ==========
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== EMAIL SETTINGS (Optional) ==========
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@rioclaro.com

# ========== LOGGING ==========
LOG_LEVEL=INFO

# ========== PRODUCTION SETTINGS ==========
# Uncomment and configure for production deployment

# DJANGO_ENVIRONMENT=production
# DEBUG=False
# SECRET_KEY=your-production-secret-key
# VITE_API_URL=https://your-domain.com
# CORS_ALLOWED_ORIGINS=https://your-domain.com

# ========== OPTIONAL SETTINGS ==========
# SESSION_TIMEOUT_MINUTES=1440
# PASSWORD_MIN_LENGTH=8
# BACKUP_RETENTION_DAYS=30
# SIMULATION_INTERVAL=30